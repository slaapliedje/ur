--- a/lib/compat/linux_termios2.h
+++ b/lib/compat/linux_termios2.h
@@ -24,12 +24,25 @@
 #include <sys/ioctl.h>
 #include <termios.h>
 
-#ifndef BOTHER
+/* Modern glibc exposes BOTHER via <termios.h> but still does NOT provide
+   struct termios2 / LINUX_IBSHIFT (those live in <asm/termbits.h>, which
+   conflicts with <termios.h>). Define each symbol independently instead of
+   gating them all on `#ifndef BOTHER`. */
 
+#ifndef BOTHER
 #define BOTHER		CBAUDEX
+#endif
+
+#ifndef LINUX_NCCS
 #define LINUX_NCCS	19
+#endif
+
+#ifndef LINUX_IBSHIFT
 #define LINUX_IBSHIFT	16
+#endif
 
+#ifndef HAVE_STRUCT_TERMIOS2
+#define HAVE_STRUCT_TERMIOS2
 struct termios2 {
         tcflag_t c_iflag;               /* input mode flags */
         tcflag_t c_oflag;               /* output mode flags */
@@ -40,7 +53,6 @@ struct termios2 {
         speed_t c_ispeed;               /* input speed */
         speed_t c_ospeed;               /* output speed */
 };
